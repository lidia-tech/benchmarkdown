# Benchmarkdown Environment Variables
# ====================================
# Copy this file to .env and fill in the values for the extractors you want to use.
# Required variables are uncommented, optional variables are commented out.

# =============================================================================
# Application Settings
# =============================================================================
# Optional:
# BENCHMARKDOWN_LOG_LEVEL=WARNING        # Logging verbosity: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: WARNING)

# =============================================================================
# Docling (Local) - IBM's open-source document processing
# =============================================================================
# No required environment variables - runs completely locally!
#
# Optional performance tuning:
# DOCLING_NUM_THREADS=8                  # Number of CPU threads (default: CPU count, range: 1-32)
# DOCLING_DOCUMENT_TIMEOUT=300.0         # Max processing time per document in seconds (default: None, min: 1.0)

# =============================================================================
# AWS Textract - Amazon's cloud-based document analysis
# =============================================================================
# Required:
TEXTRACT_S3_WORKSPACE="s3://your-bucket-name/textract-workspace/"

# AWS Credentials (choose one method):
# Method 1: AWS Profile (recommended)
AWS_PROFILE="default"

# Method 2: Direct credentials (uncomment if not using profile)
# AWS_ACCESS_KEY_ID="AKIAIOSFODNN7EXAMPLE"
# AWS_SECRET_ACCESS_KEY="wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY"

# Optional:
# AWS_DEFAULT_REGION="us-east-1"         # AWS region (default: from AWS config)

# =============================================================================
# LlamaParse - LlamaIndex's cloud-based parsing service
# =============================================================================
# Required:
LLAMA_CLOUD_API_KEY="llx-..."

# Optional (GPT-4o mode):
# OPENAI_API_KEY="sk-..."                # OpenAI API key for GPT-4o enhanced parsing

# Optional performance tuning:
# LLAMAPARSE_NUM_WORKERS=4               # Number of workers for parallel processing (default: 4, range: 1-19)
# LLAMAPARSE_MAX_TIMEOUT=2000            # Maximum timeout in seconds (default: 2000)
# LLAMAPARSE_VERBOSE=false               # Enable verbose logging (default: false)
# LLAMAPARSE_SHOW_PROGRESS=true          # Show progress for multiple files (default: true)
# LLAMAPARSE_IGNORE_ERRORS=false         # Skip errors during parsing (default: false)

# =============================================================================
# TensorLake - Cloud-based document parsing
# =============================================================================
# Required:
TENSORLAKE_API_KEY="tl_apiKey_..."

# Optional performance tuning:
# TENSORLAKE_MAX_TIMEOUT=300             # Maximum timeout in seconds (default: 300, range: 30-600)

# =============================================================================
# Azure Document Intelligence - Microsoft's document processing service
# =============================================================================
# Required:
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT="https://your-resource-name.cognitiveservices.azure.com/"
AZURE_DOCUMENT_INTELLIGENCE_KEY="your-api-key-here"

# =============================================================================
# Notes
# =============================================================================
# - Docling: Free and open-source, runs locally, no API keys needed
# - AWS Textract: Paid cloud service, requires AWS account and S3 bucket
# - LlamaParse: Paid cloud service, free tier available
# - TensorLake: Paid cloud service
# - Azure Document Intelligence: Paid cloud service, requires Azure account
#
# For more information on each extractor, see:
# - benchmarkdown/extractors/{extractor_name}/README.md
# - docs/ENVIRONMENT_VARIABLES.md
